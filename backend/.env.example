# ============================================================
# 环境变量模板 — 生产部署必填
# 复制为 .env 并填入真实值
# ============================================================

# 数据库连接
DB_URL=jdbc:mysql://localhost:3306/medical_device?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_db_password_here

# JWT 密钥 (至少 256 位强度，建议用随机生成的长字符串)
JWT_SECRET=your_jwt_secret_here_at_least_32_chars

# Spring 激活的 profile (dev: 本地开发 / prod: 生产)
SPRING_PROFILES_ACTIVE=dev
